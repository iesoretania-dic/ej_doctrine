<table>
    <thead>
        <tr>
            <th>Apellidos</th>
            <th>Nombre</th>
            <th>Fecha nacimiento</th>
            <th>Grupo</th>
        </tr>
    </thead>
    <tbody>
        {% for alumno in alumnos %}
            <tr>
                <td>{{ alumno.apellidos }}</td>
                <td>{{ alumno.nombre }}</td>
                <td>{{ alumno.fechaNacimiento|date('d/m/Y') }}</td>
                <td>{{ alumno.grupo.descripcion }}</td>
            </tr>
        {% endfor %}
    </tbody>
</table>
